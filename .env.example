# Copy to .env and adjust. No "export" needed.
# CLI flags override these values.

# LLM provider: mock | router | openai | anthropic | local
BURNER_PROVIDER=router

# Fancy LLM Router API base URL (when BURNER_PROVIDER=router)
BURNER_BASE_URL=http://localhost:8000

# Shared key for the Fancy LLM Router (when the server has api_auth_token set)
# BURNER_ROUTER_API_KEY=change-me-before-going-public

# Model name (e.g. auto, Qwen/Qwen3-32B, qwen3-32b@nebius; omit for provider default)
BURNER_MODEL=auto

# Limit how many prompts to run (omit or leave blank for all)
BURNER_MAX_PROMPTS=10

# infer = production routing; benchmark = measure + specialize per deployment
BURNER_MODE=infer
BURNER_MEASURE_DEPLOYMENTS=all

# Benchmark tuning (optional)
# BURNER_REQUEST_TIMEOUT=300
# BURNER_BENCHMARK_OPTIMIZE=true
# BURNER_BENCHMARK_MAX_REVISIONS=1
