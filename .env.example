# Copy to .env and adjust. No "export" needed.
# CLI flags override these values.

# LiteLLM model string — provider/model-name, e.g.:
#   openai/gpt-4o-mini
#   anthropic/claude-sonnet-4-20250514
#   ollama/llama3          (local via Ollama)
#   mock/mock-model        (offline stub — no credentials required)
BURNER_MODEL=mock/mock-model

# API key for the chosen provider (alternatively set <PROVIDER>_API_KEY, e.g. OPENAI_API_KEY).
# Leave blank when using the mock provider or Ollama.
# BURNER_API_KEY=

# Base URL — only needed for local/self-hosted providers (e.g. Ollama, vLLM).
# BURNER_BASE_URL=http://localhost:11434

# Limit how many prompts to run (omit or leave blank for all)
BURNER_MAX_PROMPTS=10

# infer = normal LiteLLM routing; benchmark = measure pass/fail against catalog
BURNER_MODE=infer
