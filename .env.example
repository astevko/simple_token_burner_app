# Simple Token Burner App Configuration
# Copy this file to .env and fill in your values

# LLM Provider Configuration
# PROVIDER=openai
# PROVIDER=anthropic
# PROVIDER=local
# PROVIDER=mock

# API Keys (only one needed based on your provider)
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Models (optional - defaults will be used if not specified)
# OPENAI_MODEL=gpt-3.5-turbo
# ANTHROPIC_MODEL=claude-3-sonnet-20240229
# LOCAL_MODEL=llama-3-8b

# Base URL for local LLM providers
# LOCAL_BASE_URL=http://localhost:11434

# Application settings
# LOG_DIR=logs
# MAX_PROMPTS=100
# DELAY_BETWEEN_PROMPTS=0.0
# MAX_TOKENS=1000
# TEMPERATURE=0.7